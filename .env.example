DB_HOST= # either localhost, database (if inside the Docker network) or the IP address of the database server
DB_PORT= # the port on which the database is running
DB_USER= # the username for the database
DB_PASSWORD= # the password for the database (can be generated using `openssl rand -base64 32`)
DB_NAME= # the name of the database to connect to
DB_SSLMODE= # false when running locally, require when running in production (e.g. on Neon)

CACHE_HOST= # either localhost, cache (if inside the Docker network) or the IP address of the cache server
CACHE_PORT= # the port on which the cache is running

SERVER_PORT= # the port on which the API server will listen (e.g. 8080)