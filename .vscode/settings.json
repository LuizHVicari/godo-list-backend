{
  "cSpell.words": [
    "alexedwards",
    "DBSTRING",
    "gin-gonic",
    "GOARCH",
    "Godo",
    "godoc",
    "godotenv",
    "golangci",
    "healthcheck",
    "isready",
    "jackc",
    "joho",
    "pgadmin",
    "PGPASSWORD",
    "pressly",
    "sqlc",
    "SSLMODE",
    "stdlib",
    "swaggo",
    "tmpl"
  ],
  "cSpell.ignorePaths": [
    "package-lock.json",
    "node_modules",
    "vscode-extension",
    ".git/{info,lfs,logs,refs,objects}/**",
    ".git/{index,*refs,*HEAD}",
    ".vscode",
    ".vscode-insiders",
    ".gitignore",
    ".env",
    "go.mod"
  ],
  "editor.tabSize": 4,
  "[json]": {
    "editor.quickSuggestions": {
      "strings": true
    },
    "editor.suggest.insertMode": "replace",
    "editor.tabSize": 2
  }
}
